    "drizzle-orm": "^0.30.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.3.2",
    "jose": "^5.2.0",
    "pg": "^8.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^4.3.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/sinon": "^17.0.0",
    "@types/supertest": "^6.0.0",
    "chai": "^4.4.0",
    "drizzle-kit": "^0.21.0",
    "mocha": "^10.4.0",
    "sinon": "^17.0.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
